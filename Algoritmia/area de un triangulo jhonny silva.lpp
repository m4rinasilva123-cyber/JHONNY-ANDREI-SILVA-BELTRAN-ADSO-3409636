Entero base, altura, area, perimetro

Inicio
  Escriba "Ingrese la base del rect·ngulo: "
  Lea base
  
  Escriba "Ingrese la altura del rect·ngulo: "
  Lea altura
  
  Area <- base * altura
  Perimetro <- 2 * (base + altura)
  
  Escriba "El ·rea del rect·ngulo es: ", area
  Escriba "El perÌmetro del rect·ngulo es: ", perimetro
Fin
